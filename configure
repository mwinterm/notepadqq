#!/bin/sh
# Don't set `-e'!

# Basic environment variables
test -n "$MAKE"   || MAKE="make"
test -n "$CXX"    || CXX="c++"
test -n "$CMAKE"  || CMAKE="$(command -v cmake 2>/dev/null)"
test -n "$TMPDIR" || TMPDIR="$PWD"

errorExit() {
    echo "$1"
    test x"$2" != x"1" || fail_on_missing="yes"
    test "$fail_on_missing" != "yes" || exit 1
}

help() {
cat << EOF

Usage: ./configure [OPTION]... [VAR=VALUE]...

To assign environment variables (e.g. CFLAGS...), specify them as
VAR=VALUE.  See below for descriptions of some of the useful variables.

Defaults for the options are specified in brackets.

  -h, --help              display this help and exit

  --prefix PREFIX,
  --prefix=PREFIX         install files in PREFIX [/usr/local]

  -d, --debug             build in Debug mode (default: Release)

  --fail-on-missing       return exit 1 if non-optional components are missing

  --cmake COMMAND,
  --cmake=COMMAND         specify cmake command [$CMAKE]

  -- ARGS...              extra arguments passed directly to cmake

Some influential environment variables:
  MAKE        make command
  CXX         C++ compiler
  CMAKE       cmake command
  LDFLAGS     linker flags
  CPPFLAGS    preprocessor flags
  CXXFLAGS    C++ compiler flags

EOF
}

# check "description" "command" errorExit
check() {
    printf "checking for $1... "
    t=$(basename "$2")
    command -v "$t" 2>/dev/null 1>/dev/null
    test $? -eq 0 && echo "$(command -v "$t")" || errorExit "not found!" "$3"
}

fail_on_missing="no"
BUILDTYPE="Release"
PREFIX=""
EXTRA_CMAKE_ARGS=""

while [ "$#" -ge 1 ]; do
    key="$1"
    shift

    case $key in
        -h|--help)
        help
        exit 0
        ;;
        -d|--debug)
        BUILDTYPE="Debug"
        echo "WARNING: Building in debug mode!"
        ;;
        --prefix=*)
        PREFIX="${key#*=}"
        ;;
        --prefix)
        PREFIX="$1"
        shift
        ;;
        --fail-on-missing)
        fail_on_missing="yes"
        ;;
        --cmake=*)
        CMAKE="${key#*=}"
        ;;
        --cmake)
        CMAKE="$1"
        shift
        ;;
        --)
        # Everything after -- is passed to cmake
        EXTRA_CMAKE_ARGS="$*"
        break
        ;;
        *)
        echo "WARNING: Unknown option '$key'"
        ;;
    esac
done

# --- dependency checks ---
printf "checking for cmake... "
$CMAKE --version 2>/dev/null 1>/dev/null
test $? -eq 0 && echo "$CMAKE ($($CMAKE --version | head -1))" || \
    errorExit "not found!\n  Install CMake 3.16+ or specify --cmake /path/to/cmake." 1

check "c++" "$CXX" 1
check "make" "$MAKE" 1
check "pkg-config" pkg-config 1

# check C++ compiler functionality
rm -f "$TMPDIR/test" test.cpp
cat << EOF > test.cpp
#include <iostream>
int main() { std::cout << "Hello World!" << std::endl; return 0; }
EOF
printf "checking whether c++ compiler builds test program... "
$CXX -std=c++17 -o "$TMPDIR/test" test.cpp && echo "ok" || errorExit "error!" 1
printf "checking whether compiled test program works... "
"$TMPDIR/test" 2>/dev/null 1>/dev/null && echo "ok" || errorExit "error!" 1
rm -f "$TMPDIR/test" test.cpp

# check for Qt6 via pkg-config (informational; cmake does the real check)
libraries="Qt6Core Qt6Gui Qt6Network Qt6WebEngineCore Qt6Widgets Qt6WebEngineWidgets Qt6PrintSupport Qt6Svg Qt6WebSockets Qt6WebChannel uchardet"
if [ "$(uname -s)" != "Darwin" ]; then
    libraries="$libraries Qt6DBus"
fi
for l in $libraries ; do
    printf "checking for ${l} library... "
    pkg-config --libs "$l" 2>/dev/null 1>/dev/null
    test $? -eq 0 && pkg-config --libs "$l" || errorExit "not found!"
done

# --- clean previous build ---
if [ -f "build/CMakeCache.txt" ]; then
    echo ""
    echo "Cleaning previous CMake configuration..."
    rm -rf build
fi

# --- generate build system ---
echo ""
echo "Generating build system with CMake..."

CMAKE_ARGS="-S . -B build -DCMAKE_BUILD_TYPE=$BUILDTYPE -DCMAKE_CXX_COMPILER=$CXX"
if [ -n "$PREFIX" ]; then
    CMAKE_ARGS="$CMAKE_ARGS -DCMAKE_INSTALL_PREFIX=$PREFIX"
fi
if [ -n "$CXXFLAGS" ] || [ -n "$CPPFLAGS" ]; then
    CMAKE_ARGS="$CMAKE_ARGS -DCMAKE_CXX_FLAGS=\"$CXXFLAGS $CPPFLAGS\""
fi
if [ -n "$LDFLAGS" ]; then
    CMAKE_ARGS="$CMAKE_ARGS -DCMAKE_EXE_LINKER_FLAGS=\"$LDFLAGS\""
fi
if [ -n "$EXTRA_CMAKE_ARGS" ]; then
    CMAKE_ARGS="$CMAKE_ARGS $EXTRA_CMAKE_ARGS"
fi

echo "$CMAKE $CMAKE_ARGS"
eval $CMAKE $CMAKE_ARGS || errorExit "CMake configuration failed!" 1

echo ""
echo "Configuration complete. Now run:"
echo "  make          # or: cmake --build build -j\$(nproc)"
echo "  make install  # or: cmake --install build"
